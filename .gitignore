# ============================================
# ENEM CyberQuiz - .gitignore
# ============================================

# Dependencies
node_modules/
package-lock.json

# Environment variables
.env
.env.local
.env.*.local

# Build output
dist/
build/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Editor directories and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Coverage reports
coverage/

# Cache
.cache/
.eslintcache
.prettiercache

# Uploads (if any)
uploads/
public/uploads/

# Database files (local MongoDB)
data/
*.mdb

# ============================================
# IMPORTANT: Never commit .env file!
# Your MongoDB credentials are sensitive.
# ============================================